# BLOCK27 — environment template. Copy to .env.local and fill in.
# .env.local is gitignored. Never commit real values.

# --- Supabase (public: safe in the client bundle) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (SECRET: server only, bypasses RLS, never NEXT_PUBLIC) ---
# Used only for privileged setup tasks (e.g. running the RLS test). Not used by
# product code. If this ever appears in the client bundle, treat it as leaked.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- The Hand (render provider) ---
# 'stub' until Phase 0.5. 'fashn' is not implemented yet.
HAND_PROVIDER=stub

# --- Phone verification ---
# 'stub' logs the code and accepts 000000. Dev only; throws in production.
PHONE_VERIFIER=stub
