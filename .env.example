# BLOCK27 — environment template. Copy to .env.local and fill in.
# .env.local is gitignored. Never commit real values.

# --- Supabase (public: safe in the client bundle) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (SECRET: server only, bypasses RLS, never NEXT_PUBLIC) ---
# Used only for privileged setup tasks (e.g. running the RLS test). Not used by
# product code. If this ever appears in the client bundle, treat it as leaked.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- The Brain (Anthropic) ---
# SECRET, server only, never NEXT_PUBLIC. Powers garment analysis (vision).
ANTHROPIC_API_KEY=your-anthropic-api-key
# Model for garment analysis. Haiku-tier matches the ~$0.005/garment cost model;
# bump to a stronger model here for a richer taste read.
ANALYSIS_MODEL=claude-haiku-4-5
# Model for outfit composition (taste). Sonnet-tier matches the ~$0.01–0.02
# compose budget; bump to claude-opus-4-8 for maximum taste.
OUTFIT_MODEL=claude-sonnet-5

# --- The Hand (render provider) ---
# 'stub' renders nothing; 'fashn' is the real virtual try-on provider.
HAND_PROVIDER=fashn
# SECRET, server only, never NEXT_PUBLIC. Your FASHN API key.
FASHN_API_KEY=your-fashn-api-key
# FASHN model. 'tryon-max' is the maximum-quality model (4 credits/call at 2k
# quality); 'tryon-v1.6' is the 1-credit/call lightweight model. Quality tier is
# always the top setting — there is no standard tier.
FASHN_MODEL=tryon-max
# tryon-max output resolution: 1k | 2k | 4k. Ignored by tryon-v1.6.
FASHN_RESOLUTION=2k

# --- Phone verification ---
# 'stub' logs the code and accepts 000000. Dev only; throws in production.
PHONE_VERIFIER=stub
